{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-version.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/progress-tick.sh"
          }
        ]
      }
    ]
  }
}
